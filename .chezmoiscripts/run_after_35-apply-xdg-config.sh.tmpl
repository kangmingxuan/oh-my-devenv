#!/bin/bash

set -euo pipefail

bootstrap_dir='{{ joinPath .chezmoi.sourceDir "bootstrap" }}'
scripts_dir="$bootstrap_dir/scripts"
config_file={{ .chezmoi.configFile | quote }}

source "$scripts_dir/common.sh"
install_error_trap "$0"

log_step "⚙️" "Applying XDG configuration under $XDG_CONFIG_HOME..."
bash "$scripts_dir/xdg-config.sh" apply "$config_file"
log_step "✅" "XDG configuration applied."
