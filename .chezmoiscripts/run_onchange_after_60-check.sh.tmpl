{{- $desktopBaseline := false -}}
{{- if hasKey . "desktopBaseline" -}}
{{- $desktopBaseline = .desktopBaseline -}}
{{- end -}}
{{- $isSupportedDesktop := eq (includeTemplate "desktop-platform-supported" .) "true" -}}
#!/bin/bash
{{ if eq .chezmoi.os "linux" -}}
# apt-packages.txt hash: {{ include "bootstrap/manifests/system/apt-packages.txt" | sha256sum }}
{{ else if eq .chezmoi.os "darwin" -}}
# Brewfile hash: {{ include "bootstrap/manifests/system/Brewfile" | sha256sum }}
{{ end -}}
{{ if and $desktopBaseline $isSupportedDesktop -}}
# Ghostty config hash: {{ includeTemplate "dot_config/ghostty/config.ghostty.tmpl" . | sha256sum }}
{{ if eq .chezmoi.os "darwin" -}}
# Desktop Brewfile hash: {{ include "bootstrap/manifests/desktop/Brewfile" | sha256sum }}
{{ else -}}
# Desktop apt manifest hash: {{ include "bootstrap/manifests/desktop/apt-packages.txt" | sha256sum }}
# Maple Mono manifest hash: {{ include "bootstrap/manifests/desktop/maple-mono-nf-cn.env" | sha256sum }}
# Maple Mono Fontconfig hash: {{ includeTemplate "dot_config/fontconfig/conf.d/99-oh-my-devenv-maple-mono-nf-cn.conf.tmpl" . | sha256sum }}
{{ end -}}
{{ end -}}
# go-tools.txt hash: {{ include "bootstrap/manifests/ecosystem/go-tools.txt" | sha256sum }}
# uv-tools.txt hash: {{ include "bootstrap/manifests/ecosystem/uv-tools.txt" | sha256sum }}
# oh-my-zsh-plugins.txt hash: {{ include "bootstrap/manifests/shell/oh-my-zsh-plugins.txt" | sha256sum }}
# mise config hash: {{ includeTemplate "dot_config/mise/config.toml.tmpl" | sha256sum }}

set -euo pipefail

bootstrap_dir='{{ joinPath .chezmoi.sourceDir "bootstrap" }}'
scripts_dir="$bootstrap_dir/scripts"
manifests_dir="$bootstrap_dir/manifests"

source "$scripts_dir/common.sh"
install_error_trap "$0"
source "$scripts_dir/go-env.sh"

setup_go_env

export PATH="$HOME/.local/bin:$HOME/.local/share/mise/shims:$GOBIN:$PATH"

log_step "🔎" "Running environment checks..."

errors=0
ghostty_bin=""

check_cmd() {
  if command -v "$1" >/dev/null 2>&1; then
    log_check_ok "$1"
  else
    log_check_missing "$1"
    errors=$((errors + 1))
  fi
}

check_path() {
  local path="$1"
  local name="$2"

  if [[ -e "$path" ]]; then
    log_check_ok "$name"
  else
    log_check_missing "$name"
    errors=$((errors + 1))
  fi
}

resolve_ghostty_bin() {
  local candidate=""

  if command -v ghostty >/dev/null 2>&1; then
    command -v ghostty
    return 0
  fi

  for candidate in \
    "/Applications/Ghostty.app/Contents/MacOS/Ghostty" \
    "$HOME/Applications/Ghostty.app/Contents/MacOS/Ghostty" \
    "/Applications/Ghostty.app/Contents/MacOS/ghostty" \
    "$HOME/Applications/Ghostty.app/Contents/MacOS/ghostty"; do
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

check_ghostty_config() {
  local executable="$1"

  if [[ -z "$executable" ]]; then
    log_check_missing "ghostty"
    errors=$((errors + 1))
    return 0
  fi

  log_check_ok "ghostty"
  if "$executable" +validate-config >/dev/null 2>&1; then
    log_check_ok "ghostty config"
  else
    log_warning "Ghostty could not load the managed configuration."
    errors=$((errors + 1))
  fi
}

check_maple_mono_fontconfig() {
  local active_configs=""
  local config_path="${XDG_CONFIG_HOME:-$HOME/.config}/fontconfig/conf.d/99-oh-my-devenv-maple-mono-nf-cn.conf"
  local installed_names=""
  local matched_postscript_name=""
  local postscript_name=""
  local required_names=(
    MapleMono-NF-CN-Regular
    MapleMono-NF-CN-Bold
    MapleMono-NF-CN-Italic
    MapleMono-NF-CN-BoldItalic
  )

  if ! command -v fc-list >/dev/null 2>&1 \
    || ! command -v fc-match >/dev/null 2>&1 \
    || ! command -v fc-conflist >/dev/null 2>&1; then
    log_check_missing "fontconfig"
    errors=$((errors + 1))
    return 0
  fi

  installed_names="$(fc-list -f '%{postscriptname}\n' ':family=Maple Mono NF CN')"
  for postscript_name in "${required_names[@]}"; do
    if ! grep -Fxq "$postscript_name" <<<"$installed_names"; then
      log_check_missing "$postscript_name"
      errors=$((errors + 1))
      return 0
    fi
  done

  log_check_ok "Maple Mono NF CN"

  active_configs="$(fc-conflist)"
  if ! grep -Fq "$config_path:" <<<"$active_configs"; then
    log_check_missing "Maple Mono NF CN Fontconfig rule"
    errors=$((errors + 1))
    return 0
  fi

  matched_postscript_name="$(fc-match -f '%{postscriptname}\n' monospace)"
  if [[ "$matched_postscript_name" != "MapleMono-NF-CN-Regular" ]]; then
    log_warning "Fontconfig resolves monospace to ${matched_postscript_name:-<unknown>} instead of MapleMono-NF-CN-Regular."
    errors=$((errors + 1))
    return 0
  fi

  log_check_ok "Maple Mono NF CN monospace alias"
}

check_maple_mono_macos() {
  local font_dir="$HOME/Library/Fonts"
  local font_file=""
  local required_files=(
    MapleMono-NF-CN-Regular.ttf
    MapleMono-NF-CN-Bold.ttf
    MapleMono-NF-CN-Italic.ttf
    MapleMono-NF-CN-BoldItalic.ttf
  )

  for font_file in "${required_files[@]}"; do
    if [[ ! -f "$font_dir/$font_file" ]]; then
      log_check_missing "$font_file"
      errors=$((errors + 1))
      return 0
    fi
  done

  log_check_ok "Maple Mono NF CN"
}

check_manifest_cmds() {
  local manifest="$1"
  local command_name_parser="$2"
  local tool_spec=""
  local command_name=""

  while IFS= read -r tool_spec; do
    command_name="$($command_name_parser "$tool_spec")"

    if [[ -z "$command_name" ]]; then
      log_warning "Skipping invalid manifest entry in $manifest: $tool_spec"
      errors=$((errors + 1))
      continue
    fi

    check_cmd "$command_name"
  done < <(manifest_entries "$manifest")
}

check_oh_my_zsh_plugins() {
  local manifest="$1"
  local zsh_custom_dir="$2"
  local plugin_entry=""
  local plugin_repo=""
  local plugin_path=""
  local extra_field=""

  while IFS= read -r plugin_entry; do
    read -r plugin_repo plugin_path extra_field <<<"$plugin_entry"

    if [[ -z "$plugin_repo" || -z "$plugin_path" || -n "$extra_field" ]]; then
      log_warning "Skipping invalid oh-my-zsh plugin entry in $manifest: $plugin_entry"
      errors=$((errors + 1))
      continue
    fi

    check_path "$zsh_custom_dir/$plugin_path" "${plugin_path##*/}"
  done < <(manifest_entries "$manifest")
}

detect_shell_rc_file() {
  local shell_name

  shell_name="$(basename "${SHELL:-}")"

  case "$shell_name" in
    zsh)
      printf '%s\n' "$HOME/.zshrc"
      ;;
    bash)
      printf '%s\n' "$HOME/.bashrc"
      ;;
    *)
      return 1
      ;;
  esac
}

# Core tools
check_cmd git
check_cmd curl
check_cmd zsh
check_cmd mise

# Runtimes
check_cmd go
check_cmd node
check_cmd python
check_cmd golangci-lint

# Ecosystem tools
check_manifest_cmds "$manifests_dir/ecosystem/go-tools.txt" go_tool_binary_name
check_manifest_cmds "$manifests_dir/ecosystem/uv-tools.txt" uv_tool_binary_name

# Editor-related CLI tools
check_cmd shellcheck
check_cmd shfmt

# Shell assets
check_path "$HOME/.oh-my-zsh/oh-my-zsh.sh" "oh-my-zsh"
check_oh_my_zsh_plugins "$manifests_dir/shell/oh-my-zsh-plugins.txt" "${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"

{{ if and $desktopBaseline $isSupportedDesktop -}}
# Desktop baseline
ghostty_bin="$(resolve_ghostty_bin || true)"
check_ghostty_config "$ghostty_bin"
{{ if eq .chezmoi.os "darwin" -}}
check_maple_mono_macos
{{ else -}}
check_maple_mono_fontconfig
{{ end -}}
{{ end }}

if [[ $errors -gt 0 ]]; then
  log_warning "$errors required tool(s) or asset(s) are missing."
  print_diagnostic_hints
  exit 1
fi

log_step "🎉" "All checks passed."

# --- Welcome card ---
log_info "Core tools in this environment:"
print_version_line() {
  local name="$1"
  local output=""

  if [[ "$name" != "ghostty" ]] && ! command -v "$name" >/dev/null 2>&1; then
    return 0
  fi

  case "$name" in
    chezmoi)       output="$(chezmoi --version 2>/dev/null | head -1 | awk '{print $3}' | tr -d ',')" ;;
    git)           output="$(git --version 2>/dev/null | awk '{print $3}')" ;;
    go)            output="$(go version 2>/dev/null | awk '{print $3}')" ;;
    node)          output="$(node --version 2>/dev/null)" ;;
    python)        output="$(python --version 2>/dev/null | awk '{print $2}')" ;;
    mise)          output="$(mise --version 2>/dev/null | awk '{print $1}')" ;;
    uv)            output="$(uv --version 2>/dev/null | awk '{print $2}')" ;;
    golangci-lint) output="$(golangci-lint --version 2>/dev/null | awk '/has version/ {print $4; exit}')" ;;
    ghostty)
      [[ -n "$ghostty_bin" ]] || return 0
      output="$("$ghostty_bin" --version 2>/dev/null | head -1 | awk '{print $2}')"
      ;;
    *)             output="installed" ;;
  esac

  printf '    %-16s %s\n' "$name" "${output:-installed}"
}

print_version_line chezmoi
print_version_line git
print_version_line mise
print_version_line go
print_version_line node
print_version_line python
print_version_line uv
print_version_line golangci-lint
{{ if and $desktopBaseline $isSupportedDesktop -}}
print_version_line ghostty
{{ end }}

log_info "Next steps:"
if rc_file="$(detect_shell_rc_file)"; then
  log_info "  - Reload your shell so this session sees the new PATH (try: source \"$rc_file\")."
else
  log_info "  - Reload your shell (open a new terminal) so PATH picks up the baseline tools."
fi
log_info "  - New to this baseline? Skim docs/01-onboarding.md — five-minute walkthrough of what just ran."
log_info "  - Want machine-only tweaks? Copy starters from docs/local-overlay-examples/ (nothing there is deployed by default)."
log_info "  - Need restricted-network overrides? Keep them local and start from docs/local-overlay-examples/ before the next apply."
log_info "  - Something looks wrong? Open an issue using the repository's bug-report workflow so the report stays structured."
