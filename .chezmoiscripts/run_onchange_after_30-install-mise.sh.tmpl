#!/bin/bash

set -euo pipefail

bootstrap_dir='{{ joinPath .chezmoi.sourceDir "bootstrap" }}'
scripts_dir="$bootstrap_dir/scripts"

source "$scripts_dir/common.sh"
install_error_trap "$0"

# Honor mirror-mode override for the mise installer URL. A no-op in
# external mode; in internal mode, exports DOTFILES_MISE_INSTALL_URL
# iff the user supplied it. See bootstrap/scripts/mirrors.sh.
dotfiles_apply_mirror_env

mise_bin=""

if command -v mise >/dev/null 2>&1; then
  mise_bin="$(command -v mise)"
  log_info "mise is already installed."
else
  log_step "🛠️" "Installing mise..."
{{ if eq .chezmoi.os "darwin" -}}
  BREW_CMD=""

  if command -v brew >/dev/null 2>&1; then
    BREW_CMD="$(command -v brew)"
  elif [[ -x /opt/homebrew/bin/brew ]]; then
    BREW_CMD="/opt/homebrew/bin/brew"
  elif [[ -x /usr/local/bin/brew ]]; then
    BREW_CMD="/usr/local/bin/brew"
  else
    echo "ERROR: brew not found in PATH or common install locations on macOS" >&2
    exit 1
  fi

  eval "$($BREW_CMD shellenv)"
  "$BREW_CMD" install mise
{{ else -}}
  mise_install_url="${DOTFILES_MISE_INSTALL_URL:-https://mise.run}"
  curl -fsSL "$mise_install_url" | sh
{{ end -}}
  log_step "✅" "mise installed successfully."
fi

if command -v mise >/dev/null 2>&1; then
  mise_bin="$(command -v mise)"
elif [[ -x "$HOME/.local/bin/mise" ]]; then
  mise_bin="$HOME/.local/bin/mise"
elif [[ -x /opt/homebrew/bin/mise ]]; then
  mise_bin="/opt/homebrew/bin/mise"
elif [[ -x /usr/local/bin/mise ]]; then
  mise_bin="/usr/local/bin/mise"
else
  echo "ERROR: mise installed but executable was not found" >&2
  exit 1
fi

"$mise_bin" --version

{{ if ne .chezmoi.os "darwin" -}}
zsh_completion_dir="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/site-functions"
mkdir -p "$zsh_completion_dir"
"$mise_bin" completion zsh >"$zsh_completion_dir/_mise"
log_info "Installed mise Zsh completion to $zsh_completion_dir/_mise"
{{ end -}}
