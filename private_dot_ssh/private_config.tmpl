{{- if eq .chezmoi.os "darwin" -}}
# ============================================================================
# OrbStack Integration - macOS only
# ============================================================================
Include ~/.orbstack/ssh/conf*


{{ end -}}
# ============================================================================
# Local (per-machine) SSH drop-ins - not managed by chezmoi
# The managed top-level config loads ~/.ssh/config.d/*.conf in lexical order.
# Put local-only hosts in those fragments, not in this managed file.
# ============================================================================
Include ~/.ssh/config.d/*.conf

# ============================================================================
# Global Settings - Applied to all connections
# ============================================================================
Host *
  IdentitiesOnly yes
  ControlMaster auto           # Reuse SSH connections
{{- if eq .chezmoi.os "darwin" }}
  ControlPath ~/.ssh/cm-%C
{{- else }}
  ControlPath ~/.ssh/%r@%h:%p.sock
{{- end }}
  ControlPersist 30m           # Keep connections alive for 30 minutes
  TCPKeepAlive yes             # Enable TCP keepalive
  ServerAliveInterval 60       # Send keepalive every 60 seconds
  SendEnv LANG LC_*            # Forward locale settings
