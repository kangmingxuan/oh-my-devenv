# ~/.zsh/work.zsh
#
# Work-only (or team-only) shell customizations that should not live in the
# shared baseline dot_zshrc.tmpl. The baseline sources this file as a late
# interactive hook, after its own aliases, prompt, functions, and key bindings.
#
# Typical contents:
#     - Aliases for internal CLIs.
#     - Functions that wrap internal workflows (deploys, log tails, ticket
#       lookups) without encoding any secret or host that belongs in
#       ~/.zshrc.secrets.
#     - Prompt augmentations for work-only directories.
#
# Keep this file free of secrets. Anything that would burn if it leaked goes
# in ~/.zshrc.secrets instead. Non-secret environment variables that Bash,
# Zsh, and bootstrap should all see belong in ~/.config/work/env.sh, not here.

# --------------------------------------------------------------------------
# Example: short aliases for common internal commands.
# --------------------------------------------------------------------------
# alias <short-alias>='<long-internal-command> --with common flags'

# --------------------------------------------------------------------------
# Example: a helper function. Functions composed from standard tools tend
# to age better than aliases when the underlying CLI evolves.
# --------------------------------------------------------------------------
# corp_ticket() {
#     local ticket="${1:?usage: corp_ticket <TICKET-ID>}"
#     open "https://<ticket-system>/browse/${ticket}"
# }

# --------------------------------------------------------------------------
# Example: prompt suffix that shows you are on a work machine, only when
# inside a work checkout. Keeps your personal prompt untouched elsewhere.
# --------------------------------------------------------------------------
# _work_prompt_suffix() {
#     case "$PWD" in
#         "$HOME"/workspace/corp/*) print -nP "%F{yellow}[work]%f " ;;
#     esac
# }
# precmd_functions+=(_work_prompt_suffix)
