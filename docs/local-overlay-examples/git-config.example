# $XDG_CONFIG_HOME/oh-my-devenv/git/config
#
# Local Git overrides that are intentionally kept out of the shared baseline.
# Copy this file to $XDG_CONFIG_HOME/oh-my-devenv/git/config.
#
# The managed ~/.gitconfig already provides your default Git identity.
# Use this file for private per-machine preferences and optional guardrails.
# Anything you set here wins over the baseline defaults because the managed
# ~/.gitconfig includes this file last.

# --------------------------------------------------------------------------
# Optional: user-owned Git guardrails.
#
# Git 2.54+ can register this machine-wide guardrail without replacing each
# repository's .git/hooks/pre-push. The command must be an absolute path because
# Git does not expand $XDG_CONFIG_HOME in config values. See git-pre-push.example
# and the local-overlay README for the complete setup.
# --------------------------------------------------------------------------
# [hook "oh-my-devenv-identity-guard"]
#     event = pre-push
#     command = <absolute-xdg-config-home>/oh-my-devenv/git/hooks/pre-push

# --------------------------------------------------------------------------
# Optional: note for repos that truly need a non-default identity.
#
# Keep the machine-wide default identity in the managed ~/.gitconfig. For the
# occasional repo that needs a different identity, prefer repo-local config in
# that repository instead of another shared overlay file:
#
# git -C ~/workspace/personal/<repo> config user.name "<your-real-name>"
# git -C ~/workspace/personal/<repo> config user.email "<your.personal.email@example.com>"

# If you use multiple worktrees that each need their own identity, keep those
# per-worktree identities in the worktree configs, not in this machine overlay:
#
# git -C ~/workspace/<repo> config extensions.worktreeConfig true
# git -C ~/workspace/<repo> config --worktree user.email "<identity-for-this-worktree>"

# --------------------------------------------------------------------------
# Optional: insteadOf for host-specific Git URLs.
#
# Use this section for host-specific rewrites that should stay local to your
# machine or team.
# --------------------------------------------------------------------------
# [url "git@<preferred-git-host>:"]
#     insteadOf = https://<preferred-git-host>/

# --------------------------------------------------------------------------
# Optional: pull / push preferences that vary by person.
# --------------------------------------------------------------------------
# [pull]
#     rebase = true
# [push]
#     default = current
