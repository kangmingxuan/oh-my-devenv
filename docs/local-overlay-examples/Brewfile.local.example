# $XDG_CONFIG_HOME/oh-my-devenv/Brewfile.local
#
# macOS-only Homebrew apps and CLIs that are useful on this machine but do not
# belong in the shared baseline.
#
# When this file exists before the system-package hook runs, the macOS
# bootstrap installs it automatically.
#
# After first bootstrap, re-sync local changes explicitly:
#
#   brew bundle install --file="$XDG_CONFIG_HOME/oh-my-devenv/Brewfile.local"

# Personal editor / app choices. Uncomment only what you actually want.
# cask "visual-studio-code"
# brew "mas"
