# $XDG_CONFIG_HOME/oh-my-devenv/bootstrap.env
#
# Non-secret settings read only by bootstrap scripts. Shell startup does not
# source this file. Keep it compatible with Bash and limit it to exported
# variables; aliases, functions, prompt customizations, and secrets do not
# belong here.
#
# XDG_CONFIG_HOME is resolved before this file is read and must not be changed
# here. Export a custom absolute XDG_CONFIG_HOME before starting chezmoi.

# --------------------------------------------------------------------------
# Optional mirror mode for restricted networks.
# --------------------------------------------------------------------------
# export DOTFILES_MIRROR_MODE=auto
# export DOTFILES_INTERNAL_PROBE_URL='https://<internal-probe>/healthz'
# export DOTFILES_GOPROXY='https://<internal-go-proxy>'
# export DOTFILES_UV_INDEX_URL='https://<internal-uv-tool-mirror>/simple'
# export DOTFILES_HOMEBREW_API_DOMAIN='https://<internal-homebrew-api>'
# export DOTFILES_HOMEBREW_BOTTLE_DOMAIN='https://<internal-homebrew-bottles>'
# export DOTFILES_MISE_INSTALL_URL='https://<internal-mise-installer>'
# export DOTFILES_OH_MY_ZSH_GIT_URL='https://<internal-oh-my-zsh-repo>'

# Maple Mono is separately pinned. An alternate URL must serve the exact same
# archive because bootstrap still verifies the repository-pinned SHA-256.
# export DOTFILES_MAPLE_MONO_URL='https://<artifact-mirror>/MapleMono-NF-CN-unhinted.zip'

# Optional macOS Homebrew inputs used during first bootstrap.
# export DOTFILES_INSTALL_REPO_OPTIONAL_BREWFILE=1
# export DOTFILES_EXTRA_BREWFILES="$XDG_CONFIG_HOME/oh-my-devenv/Brewfile.local"

# Reinstall Go and Python tools even when their idempotency probes succeed.
# export DOTFILES_FORCE_REINSTALL=1
