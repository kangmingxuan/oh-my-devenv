# ~/.ssh/config.d/<pick-a-name>.conf
#
# One user-owned drop-in fragment loaded by the baseline-managed ~/.ssh/config
# via `Include ~/.ssh/config.d/*.conf` before the global `Host *` block.
# Keep local additions in this drop-in directory instead of editing the managed
# top-level config.
#
# Prerequisite (one-time):
#     1. If you are not using the baseline-managed ~/.ssh/config, make sure your
#        top-level config includes `Include ~/.ssh/config.d/*.conf` before any
#        `Host *` catch-all.
#     2. `chmod 600 ~/.ssh/config ~/.ssh/config.d/*.conf` — SSH refuses to
#        parse loose-permission configs.

# --------------------------------------------------------------------------
# Example: a corp host reached via an SSH bastion.
# --------------------------------------------------------------------------
Host <corp-alias>
    HostName <corp-target-host>
    User <your-corp-login>
    Port 22
    IdentityFile ~/.ssh/<your-corp-key>
    IdentitiesOnly yes
    ProxyJump <bastion-alias>

# --------------------------------------------------------------------------
# Example: the bastion itself.
# --------------------------------------------------------------------------
Host <bastion-alias>
    HostName <bastion-host>
    User <your-corp-login>
    Port 22
    IdentityFile ~/.ssh/<your-corp-key>
    IdentitiesOnly yes

# --------------------------------------------------------------------------
# Example: forward an agent only for specific trusted hosts. Avoid enabling
# agent forwarding globally; it exposes your local agent to every host you
# connect to, including ones that can impersonate others afterwards.
# --------------------------------------------------------------------------
# Host <trusted-alias>
#     HostName <trusted-host>
#     ForwardAgent yes
