# $XDG_CONFIG_HOME/oh-my-devenv/secrets.sh
#
# Shared shell secrets for interactive Bash and Zsh sessions. The baseline
# sources this file from ~/.bashrc and ~/.zshrc only; bootstrap and other
# non-interactive shells do not read it automatically. Keep this file
# shell-compatible so both shells can source it.
#
# Safety rules:
#   - This file is owned by YOUR user. Do not commit it anywhere, even to a
#     private overlay repo.
#   - Keep persistent non-secret shell exports in env.sh.
#   - Keep shell-specific helpers in zshrc.zsh or bashrc.bash.
#   - `chmod 600 "$XDG_CONFIG_HOME/oh-my-devenv/secrets.sh"` so other local users cannot read it.
#   - Rotate any token that has ever landed in a committed file.
#
# Automation / agent note:
#   - Codex, Claude Code, and similar tools usually execute non-interactive
#     shell commands, so they will not see these exports just because this file
#     exists.
#   - When an automation needs a token, start the tool from a shell that has
#     sourced this file, or inject the token through the tool's own secret/env
#     configuration.

# Examples (replace with your real values in the real overlay, never here):
#
# export GIT_HOST_TOKEN="<your-hosted-git-token>"
# export GITHUB_TOKEN="<your-github-pat>"
# export ANTHROPIC_API_KEY="<your-anthropic-key>"

# Example: start an agent with these secrets in its inherited environment.
# source "$XDG_CONFIG_HOME/oh-my-devenv/secrets.sh"
# codex
# claude

# If a secret is machine-local, guard it to avoid surprising yourself on
# another machine:
#
# if [ "$(hostname -s)" = "<your-machine-hostname>" ]; then
#   export SOME_LOCAL_ONLY_SECRET="<value>"
# fi
