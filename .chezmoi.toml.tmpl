{{- $gitName := promptStringOnce . "gitName" "Git author name" "" -}}
{{- $gitEmail := promptStringOnce . "gitEmail" "Git author email address" "" -}}
{{- $isSupportedDesktop := eq (includeTemplate "desktop-platform-supported" .) "true" -}}
{{- $hasGraphicalSession := or
    (ne (env "XDG_CURRENT_DESKTOP") "")
    (ne (env "WAYLAND_DISPLAY") "")
    (ne (env "DISPLAY") "")
-}}
{{- $desktopBaselineDefault := or
    (eq .chezmoi.os "darwin")
    (and $isSupportedDesktop $hasGraphicalSession)
-}}
{{- $desktopBaselinePrompt := "Install desktop baseline (Ghostty + Maple Mono NF CN)" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{- $desktopBaselinePrompt = "Install macOS desktop baseline (Ghostty + Maple Mono NF CN + OrbStack)" -}}
{{- end -}}
{{- $desktopBaseline := promptBoolOnce . "desktopBaseline" $desktopBaselinePrompt $desktopBaselineDefault -}}

[status]
    # Keep routine run_* hooks out of `chezmoi status` so the output
    # reflects file drift, not the banner/bootstrap scripts that apply
    # will execute by design.
    exclude = ["scripts"]

[diff]
    # Match status output: routine run_* hooks are reviewed through git,
    # not as destination-file drift.
    exclude = ["scripts"]

[data]
    name = {{ $gitName | quote }}
    email = {{ $gitEmail | quote }}
    desktopBaseline = {{ $desktopBaseline }}
