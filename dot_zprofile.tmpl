# ~/.zprofile
# Login shell initialization.
# Keep this file lightweight by delegating environment setup to ~/.zsh/env.zsh.

# shellcheck disable=SC1091
[[ -f "$HOME/.zsh/env.zsh" ]] && source "$HOME/.zsh/env.zsh"

{{ if eq .chezmoi.os "darwin" -}}
# OrbStack command-line tools and shell integration.
# Keep this managed here so chezmoi does not overwrite OrbStack's local injection.
[[ -f "$HOME/.orbstack/shell/init.zsh" ]] && source "$HOME/.orbstack/shell/init.zsh"
{{- end }}
