# ~/.bashrc
# Interactive shell configuration for Bash.
# Put aliases, functions, and interactive settings here.
# Keep PATH and core environment variables in ~/.bash/env.bash.

# Exit early if the shell is not interactive.
case $- in
  *i*) ;;
  *) return;;
esac

# Load shared environment for interactive non-login shells (e.g. VS Code terminals).
# shellcheck disable=SC1091
[[ -f "$HOME/.bash/env.bash" ]] && source "$HOME/.bash/env.bash"

# Load local secrets that are intentionally not tracked.
# shellcheck disable=SC1091
[[ -f "$XDG_CONFIG_HOME/oh-my-devenv/secrets.sh" ]] && source "$XDG_CONFIG_HOME/oh-my-devenv/secrets.sh"

# --- History Settings ---
# Do not store duplicate lines or lines starting with spaces in history.
HISTCONTROL=ignoreboth
# Append to the history file instead of overwriting it.
shopt -s histappend
# Configure history size in memory and on disk.
HISTSIZE=5000
HISTFILESIZE=20000

# --- Window Size ---
# Check window size after each command and, if needed,
# update LINES and COLUMNS.
shopt -s checkwinsize

# --- Prompt (PS1) ---
# Provide a clean, colored prompt, especially on minimal Linux servers.
# Format: user@host:dir$

# Detect color capability from TERM type.
case "$TERM" in
  xterm-color|*-256color) color_prompt=yes;;
esac

# Fall back to tput detection when forced or TERM didn't match.
if [ -z "$color_prompt" ] && [ -x /usr/bin/tput ] && tput setaf 1 >&/dev/null; then
  color_prompt=yes
fi

if [ "$color_prompt" = yes ]; then
  PS1='\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '
else
  PS1='\u@\h:\w\$ '
fi
unset color_prompt

# --- Aliases & Colors ---
# Enable color support and common aliases.
if [ -x /usr/bin/dircolors ]; then
  if [ -r ~/.dircolors ]; then
    eval "$(dircolors -b ~/.dircolors)"
  else
    eval "$(dircolors -b)"
  fi
  alias ls='ls --color=auto'
  alias grep='grep --color=auto'
  alias fgrep='fgrep --color=auto'
  alias egrep='egrep --color=auto'
fi

# Additional ls aliases.
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

# --- Bash Completion ---
# Enable programmable completion features.
# This is optional when completion is already enabled globally.
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    # shellcheck disable=SC1091
    source /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    # shellcheck disable=SC1091
    source /etc/bash_completion
  fi
fi

# --- Custom Configurations ---
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate bash)"

  # Register completions only when the loaded bash-completion library exposes
  # the helpers required by `mise completion bash`.
  if declare -F _comp_initialize >/dev/null 2>&1 && ! complete -p mise >/dev/null 2>&1; then
    eval "$(mise completion bash 2>/dev/null)"
  fi
fi

if command -v uv >/dev/null 2>&1 && ! complete -p uv >/dev/null 2>&1; then
  eval "$(uv generate-shell-completion bash 2>/dev/null)"
fi

if command -v fzf >/dev/null 2>&1; then
  if fzf_shell_integration="$(fzf --bash 2>/dev/null)" && [[ -n "$fzf_shell_integration" ]]; then
    eval "$fzf_shell_integration"
  else
    if [[ -f /usr/share/bash-completion/completions/fzf ]]; then
      # shellcheck disable=SC1091
      source /usr/share/bash-completion/completions/fzf
    fi
    if [[ -f /usr/share/doc/fzf/examples/key-bindings.bash ]]; then
      # shellcheck disable=SC1091
      source /usr/share/doc/fzf/examples/key-bindings.bash
    fi
  fi
  unset fzf_shell_integration
fi

# Set GPG_TTY for GPG agent to work properly in terminal.
if [[ -t 0 ]]; then
  GPG_TTY="$(tty)"
  export GPG_TTY
fi

# Load local interactive overlay last so it can intentionally override
# baseline aliases, prompt, functions, and key bindings. Put persistent non-secret
# environment variables in $XDG_CONFIG_HOME/oh-my-devenv/env.sh instead.
# shellcheck disable=SC1091
[[ -f "$XDG_CONFIG_HOME/oh-my-devenv/bashrc.bash" ]] && source "$XDG_CONFIG_HOME/oh-my-devenv/bashrc.bash"
