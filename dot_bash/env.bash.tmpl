# ~/.bash/env.bash
# Shared environment initialization for both login and interactive shells.
# Idempotent and safe to source multiple times.

# Guard against multiple sourcing.
if [[ -n "${__BASH_ENV_DONE-}" ]]; then
  return 0
fi
__BASH_ENV_DONE=1

# --- PATH Helpers ---
# Helpers for PATH manipulation in Bash.
path_remove() {
  local d="$1"
  PATH=":$PATH:"
  PATH="${PATH//:$d:/:}"
  PATH="${PATH#:}"
  PATH="${PATH%:}"
}

path_prepend() {
  local d="$1"
  [[ -n "$d" && -d "$d" ]] || return 0
  path_remove "$d"
  export PATH="$d${PATH:+:$PATH}"
}

path_append() {
  local d="$1"
  [[ -n "$d" && -d "$d" ]] || return 0
  path_remove "$d"
  export PATH="${PATH:+$PATH:}$d"
}

path_reorder_front() {
  local d
  local -a dirs=("$@")
  # Iterate backward so the first argument ends up at the front.
  for (( i=${#dirs[@]}-1; i>=0; i-- )); do
    d="${dirs[$i]}"
    [[ -n "$d" && -d "$d" ]] || continue
    path_prepend "$d"
  done
}

# --- Compatibility Helpers ---
if ! command -v fd >/dev/null 2>&1 && command -v fdfind >/dev/null 2>&1; then
  fd() {
    command fdfind "$@"
  }
fi

if ! command -v bat >/dev/null 2>&1 && command -v batcat >/dev/null 2>&1; then
  bat() {
    command batcat "$@"
  }
fi

# --- Tool Initialization ---
{{- if eq .chezmoi.os "darwin" }}

# Homebrew shellenv (sets PATH/MANPATH/INFOPATH...)
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif command -v brew >/dev/null 2>&1; then
  eval "$(brew shellenv)"
fi
{{- end }}

# Go
# Keep GOPATH for backward compatibility, but prefer GOBIN for PATH management.
export GOPATH="${GOPATH:-$HOME/go}"
export GOBIN="${GOBIN:-$GOPATH/bin}"
path_prepend "$GOBIN"

# User scripts.
path_prepend "$HOME/.local/bin"
path_prepend "$HOME/bin"

# Mise shims keep tool resolution stable when hooks are not active.
export MISE_SHIMS_DIR="${MISE_SHIMS_DIR:-$HOME/.local/share/mise/shims}"
path_prepend "$MISE_SHIMS_DIR"

# JetBrains Toolbox scripts. path_append is a no-op when the directory does not
# exist, so this line has no effect on machines without JetBrains Toolbox.
{{- if eq .chezmoi.os "darwin" }}
path_append "$HOME/Library/Application Support/JetBrains/Toolbox/scripts"
{{- else }}
path_append "$HOME/.local/share/JetBrains/Toolbox/scripts"
{{- end }}

# --- Final PATH Ordering ---
path_reorder_front \
  "$MISE_SHIMS_DIR" \
  "$HOME/bin" \
  "$HOME/.local/bin" \
  "$GOBIN" \
  "${HOMEBREW_PREFIX:+$HOMEBREW_PREFIX/bin}" \
  "${HOMEBREW_PREFIX:+$HOMEBREW_PREFIX/sbin}"

export PATH

# Other environment variables.
# Pick a `bat` theme that is bundled with every recent `bat` release so new
# machines never see an "unknown theme" warning on first run. Override in a
# local overlay (for example `~/.bashrc.secrets`) to use a different theme.
export BAT_THEME='TwoDark'

# Load shared non-secret work environment variables if present.
# This file must stay shell-compatible so Bash, Zsh, and bootstrap can share it.
# shellcheck disable=SC1090
[[ -f "${XDG_CONFIG_HOME:-$HOME/.config}/work/env.sh" ]] && source "${XDG_CONFIG_HOME:-$HOME/.config}/work/env.sh"
