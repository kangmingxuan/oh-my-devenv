# Mirror-mode manifest.
#
# Three whitespace-separated columns:
#
#   <mode> <ENV_VAR_NAME> <value>
#
# Supported modes:
#
#   external   The public, globally reachable default contract. External mode
#              does not export these rows; consumers keep their normal defaults.
#              The rows document expected defaults and give tests a stable
#              public value to defend.
#   internal   Corporate / mirrored values. All <placeholder> entries are
#              intentional: users override them per-machine via
#              DOTFILES_<ENV_VAR_NAME> env variables (see
#              docs/local-overlay-examples/env.sh.example). This file never
#              ships a real corporate hostname.
#
# Lines starting with `#` and blank lines are ignored.
# Add new consumers by appending two rows (external + internal) and
# wiring the target env var in the corresponding install script.

external GOPROXY                       proxy.golang.org,direct
internal GOPROXY                       <placeholder-internal-goproxy>

external UV_INDEX_URL                  https://pypi.org/simple
internal UV_INDEX_URL                  <placeholder-internal-pypi-simple>

external HOMEBREW_API_DOMAIN           https://formulae.brew.sh/api
internal HOMEBREW_API_DOMAIN           <placeholder-internal-brew-api>

external HOMEBREW_BOTTLE_DOMAIN        https://ghcr.io/v2/homebrew/core
internal HOMEBREW_BOTTLE_DOMAIN        <placeholder-internal-brew-bottle>

external DOTFILES_MISE_INSTALL_URL     https://mise.run
internal DOTFILES_MISE_INSTALL_URL     <placeholder-internal-mise-installer>

external DOTFILES_OH_MY_ZSH_GIT_URL    https://github.com/ohmyzsh/ohmyzsh.git
internal DOTFILES_OH_MY_ZSH_GIT_URL    <placeholder-internal-oh-my-zsh-git>
